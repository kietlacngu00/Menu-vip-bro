-- ===========================================
-- TẠO CÁC NÚT TAB
-- ===========================================
local tabWidth = (menuWidth - 40) / #tabs

for i, tab in ipairs(tabs) do
    local btn = Instance.new("TextButton")
    btn.Parent = TabFrame
    btn.Size = UDim2.new(0, tabWidth - 2, 1, -10)
    btn.Position = UDim2.new(0, (i-1) * tabWidth + 5, 0, 5)
    btn.Text = tab.name
    btn.TextColor3 = i == currentTab and Color3.fromRGB(0, 255, 128) or Color3.fromRGB(200, 200, 200)
    btn.TextSize = isMobile and 12 or 14
    btn.TextWrapped = true
    btn.BackgroundColor3 = i == currentTab and Color3.fromRGB(0, 50, 30) or Color3.fromRGB(30, 30, 30)
    btn.BorderSizePixel = 0
    btn.AutoButtonColor = false
    
    btn.MouseButton1Click:Connect(function()
        currentTab = i
        for j, b in ipairs(TabFrame:GetChildren()) do
            if b:IsA("TextButton") then
                b.TextColor3 = j == i and Color3.fromRGB(0, 255, 128) or Color3.fromRGB(200, 200, 200)
                b.BackgroundColor3 = j == i and Color3.fromRGB(0, 50, 30) or Color3.fromRGB(30, 30, 30)
            end
        end
        
        ClearContent()
        if i == 1 then CreateTab1()
        elseif i == 2 then CreateTab2()
        elseif i == 3 then CreateTab3()
        elseif i == 4 then CreateTab4()
        elseif i == 5 then CreateTab5()
        elseif i == 6 then CreateTab6()
        elseif i == 7 then CreateTab7()
        elseif i == 8 then CreateTab8()
        elseif i == 9 then CreateTab9()
        end
    end)
    
    table.insert(tabButtons, btn)
end

