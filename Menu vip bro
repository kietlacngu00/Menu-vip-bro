-- TẠO NỘI DUNG CHO TAB 1 (INFO) - MẪU
-- ===========================================
local function CreateTab1()
    local yPos = 0
    
    local infoFrame = Instance.new("Frame")
    infoFrame.Parent = ContentFrame
    infoFrame.Size = UDim2.new(1, -10, 0, 120)
    infoFrame.Position = UDim2.new(0, 5, 0, yPos)
    infoFrame.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
    infoFrame.BorderSizePixel = 0
    yPos = yPos + 125
    
    local player = game.Players.LocalPlayer
    local stats = player:FindFirstChild("leaderstats")
    
    local infoText = Instance.new("TextLabel")
    infoText.Parent = infoFrame
    infoText.Size = UDim2.new(1, -20, 1, -10)
    infoText.Position = UDim2.new(0, 10, 0, 5)
    infoText.Text = "👤 Tên: " .. player.Name .. "\n" ..
                    "💰 Beli: " .. (stats and stats:FindFirstChild("Beli") and stats.Beli.Value or "N/A") .. "\n" ..
                    "💎 Fragments: " .. (stats and stats:FindFirstChild("Fragments") and stats.Fragments.Value or "N/A") .. "\n" ..
                    "📊 Level: " .. (stats and stats:FindFirstChild("Level") and stats.Level.Value or "N/A")
    infoText.TextColor3 = Color3.fromRGB(200, 200, 200)
    infoText.TextXAlignment = Enum.TextXAlignment.Left
    infoText.TextYAlignment = Enum.TextYAlignment.Top
    infoText.TextSize = 16
    infoText.Font = Enum.Font.Gotham
    infoText.BackgroundTransparency = 1
    
    local refreshBtn = CreateButton(ContentFrame, "🔄 LÀM MỚI", yPos, Color3.fromRGB(0, 100, 150))
    refreshBtn.MouseButton1Click:Connect(function()
        ClearContent()
        CreateTab1()
    end)
end

